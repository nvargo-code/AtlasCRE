generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]
}

model User {
  id             String            @id @default(cuid())
  email          String            @unique
  passwordHash   String
  name           String?
  role           Role              @default(USER)
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  createdAt      DateTime          @default(now())
  savedSearches  SavedSearch[]
  favorites      FavoriteListing[]
}

enum Role {
  USER
  ADMIN
}

model ListingSource {
  id            String           @id @default(cuid())
  name          String           @unique
  slug          String           @unique
  baseUrl       String?
  enabled       Boolean          @default(true)
  lastRunAt     DateTime?
  lastRunStatus String?
  rawListings   RawListing[]
  variants      ListingVariant[]
}

model RawListing {
  id         String        @id @default(cuid())
  sourceId   String
  source     ListingSource @relation(fields: [sourceId], references: [id])
  externalId String
  market     String
  rawData    Json
  fetchedAt  DateTime      @default(now())

  @@unique([sourceId, externalId])
  @@index([market])
}

model Listing {
  id            String            @id @default(cuid())
  address       String
  city          String
  state         String            @default("TX")
  zip           String?
  lat           Float
  lng           Float
  market        String
  propertyType  String
  listingType   String
  buildingSf    Float?
  lotSizeAcres  Float?
  priceAmount   Float?
  priceUnit     String?
  yearBuilt     Int?
  brokerName    String?
  brokerCompany String?
  description   String?
  imageUrl      String?
  status        String            @default("active")
  dedupeKey     String            @unique
  // Residential fields
  beds          Int?
  baths         Float?
  garageSpaces  Int?
  stories       Int?
  propSubType   String?
  searchMode    String            @default("commercial")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  variants        ListingVariant[]
  favorites       FavoriteListing[]
  photos          ListingPhoto[]
  processedEmails ProcessedEmail[]

  @@index([market])
  @@index([propertyType])
  @@index([listingType])
  @@index([lat, lng])
  @@index([status])
  @@index([searchMode])
}

model ListingVariant {
  id          String        @id @default(cuid())
  listingId   String
  listing     Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sourceId    String
  source      ListingSource @relation(fields: [sourceId], references: [id])
  externalId  String
  sourceUrl   String?
  priceAmount Float?
  priceUnit   String?
  buildingSf  Float?
  description String?
  brokerName  String?
  brokerPhone String?
  brokerEmail String?
  imageUrl    String?
  rawData     Json?
  fetchedAt   DateTime      @default(now())

  @@unique([sourceId, externalId])
  @@index([listingId])
}

// ── Email scanning pipeline ──────────────────────────────────────────────────

model ProcessedEmail {
  id             String   @id @default(cuid())
  gmailMessageId String   @unique // Gmail message ID to avoid re-processing
  threadId       String?  // Gmail thread ID
  from           String
  subject        String
  receivedAt     DateTime
  processedAt    DateTime @default(now())
  // Detection results
  isPocketListing Boolean  @default(false)
  confidence      Float    @default(0)
  keywords        String[] // Which keywords matched
  mlsNumber       String?  // MLS# if found (for context)
  // Outcome
  listingId       String?  // If a listing was created from this email
  listing         Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  status          String   @default("processed") // processed | ingested | skipped | error
  errorMessage    String?
  rawBody         String?  // Store email body for debugging
  extractedData   Json?    // Parsed listing data

  @@index([gmailMessageId])
  @@index([processedAt])
  @@index([isPocketListing])
}

model ListingPhoto {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String   // Stored URL (could be original or re-hosted)
  sourceUrl String?  // Original URL where we found it
  position  Int      @default(0) // Display order
  createdAt DateTime @default(now())

  @@index([listingId])
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  filters   Json
  createdAt DateTime @default(now())
}

model FavoriteListing {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  notes     String?
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}
